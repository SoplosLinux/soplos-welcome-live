#: core/application.py:310
msgid ""
"\n"
"Soplos Welcome Live 2.0 - Live ISO Welcome Application\n"
"\n"
"Usage: soplos-welcome-live [OPTIONS]\n"
"\n"
"Options:\n"
"  -h, --help              Show this help message\n"
"  -v, --version           Show version information\n"
"  --lang=LANG             Set language (es, en, fr, de, pt, it, ro, ru)\n"
"  --theme=THEME           Set theme (base, light, dark)\n"
"  --chroot                Open chroot mode directly\n"
"  --debug                 Enable debug mode\n"
"\n"
"Examples:\n"
"  soplos-welcome-live                    # Start with auto-detected "
"settings\n"
"  soplos-welcome-live --lang=es          # Start in Spanish\n"
"  soplos-welcome-live --theme=dark       # Start with dark theme\n"
"  soplos-welcome-live --chroot           # Open chroot mode\n"
"\n"
"For more information, visit: https://soplos.org\n"
msgstr ""
"\n"
"Soplos Welcome Live 2.0 - Live-ISO Willkommensanwendung\n"
"\n"
"Verwendung: soplos-welcome-live [OPTIONEN]\n"
"\n"
"Optionen:\n"
"  -h, --help              Diese Hilfe anzeigen\n"
"  -v, --version           Versionsinformationen anzeigen\n"
"  --lang=LANG             Sprache festlegen (es, en, fr, de, pt, it, ro, ru)\n"
"  --theme=THEMA           Thema festlegen (base, light, dark)\n"
"  --chroot                Chroot-Modus direkt öffnen\n"
"  --debug                 Debug-Modus aktivieren\n"
"\n"
"Beispiele:\n"
"  soplos-welcome-live                    # Mit automatisch erkannten "
"Einstellungen starten\n"
"  soplos-welcome-live --lang=es          # In Spanisch starten\n"
"  soplos-welcome-live --theme=dark       # Mit dunklem Thema starten\n"
"  soplos-welcome-live --chroot           # Chroot-Modus öffnen\n"
"\n"
"Für weitere Informationen besuchen Sie: https://soplos.org\n"

