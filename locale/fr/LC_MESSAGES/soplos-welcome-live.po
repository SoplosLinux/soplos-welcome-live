#: core/application.py:310
msgid ""
"\n"
"Soplos Welcome Live 2.0 - Live ISO Welcome Application\n"
"\n"
"Usage: soplos-welcome-live [OPTIONS]\n"
"\n"
"Options:\n"
"  -h, --help              Show this help message\n"
"  -v, --version           Show version information\n"
"  --lang=LANG             Set language (es, en, fr, de, pt, it, ro, ru)\n"
"  --theme=THEME           Set theme (base, light, dark)\n"
"  --chroot                Open chroot mode directly\n"
"  --debug                 Enable debug mode\n"
"\n"
"Examples:\n"
"  soplos-welcome-live                    # Start with auto-detected "
"settings\n"
"  soplos-welcome-live --lang=es          # Start in Spanish\n"
"  soplos-welcome-live --theme=dark       # Start with dark theme\n"
"  soplos-welcome-live --chroot           # Open chroot mode\n"
"\n"
"For more information, visit: https://soplos.org\n"
msgstr ""
"\n"
"Soplos Welcome Live 2.0 - Application de bienvenue pour ISO Live\n"
"\n"
"Usage: soplos-welcome-live [OPTIONS]\n"
"\n"
"Options:\n"
"  -h, --help              Affiche ce message d'aide\n"
"  -v, --version           Affiche les informations de version\n"
"  --lang=LANG             Définit la langue (es, en, fr, de, pt, it, ro, ru)\n"
"  --theme=THEME           Définit le thème (base, light, dark)\n"
"  --chroot                Ouvre le mode chroot directement\n"
"  --debug                 Active le mode débogage\n"
"\n"
"Exemples:\n"
"  soplos-welcome-live                    # Démarre avec les paramètres "
"détectés\n"
"  soplos-welcome-live --lang=es          # Démarre en espagnol\n"
"  soplos-welcome-live --theme=dark       # Démarre avec le thème sombre\n"
"  soplos-welcome-live --chroot           # Ouvre le mode chroot\n"
"\n"
"Pour plus d'informations, visitez : https://soplos.org\n"

