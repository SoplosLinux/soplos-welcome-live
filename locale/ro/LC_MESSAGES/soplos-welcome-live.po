#: core/application.py:310
msgid ""
"\n"
"Soplos Welcome Live 2.0 - Live ISO Welcome Application\n"
"\n"
"Usage: soplos-welcome-live [OPTIONS]\n"
"\n"
"Options:\n"
"  -h, --help              Show this help message\n"
"  -v, --version           Show version information\n"
"  --lang=LANG             Set language (es, en, fr, de, pt, it, ro, ru)\n"
"  --theme=THEME           Set theme (base, light, dark)\n"
"  --chroot                Open chroot mode directly\n"
"  --debug                 Enable debug mode\n"
"\n"
"Examples:\n"
"  soplos-welcome-live                    # Start with auto-detected "
"settings\n"
"  soplos-welcome-live --lang=es          # Start in Spanish\n"
"  soplos-welcome-live --theme=dark       # Start with dark theme\n"
"  soplos-welcome-live --chroot           # Open chroot mode\n"
"\n"
"For more information, visit: https://soplos.org\n"
msgstr ""
"\n"
"Soplos Welcome Live 2.0 - Aplicație de bun venit ISO Live\n"
"\n"
"Utilizare: soplos-welcome-live [OPȚIUNI]\n"
"\n"
"Opțiuni:\n"
"  -h, --help              Arată acest mesaj de ajutor\n"
"  -v, --version           Arată informațiile despre versiune\n"
"  --lang=LANG             Setează limba (es, en, fr, de, pt, it, ro, ru)\n"
"  --theme=TEMĂ            Setează tema (base, light, dark)\n"
"  --chroot                Deschide direct modul chroot\n"
"  --debug                 Activează modul de depanare\n"
"\n"
"Exemple:\n"
"  soplos-welcome-live                    # Pornește cu setările detectate "
"automat\n"
"  soplos-welcome-live --lang=es          # Pornește în spaniolă\n"
"  soplos-welcome-live --theme=dark       # Pornește cu tema întunecată\n"
"  soplos-welcome-live --chroot           # Deschide modul chroot\n"
"\n"
"Pentru mai multe informații, vizitați: https://soplos.org\n"

