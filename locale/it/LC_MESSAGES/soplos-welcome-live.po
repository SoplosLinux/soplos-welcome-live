#: core/application.py:310
msgid ""
"\n"
"Soplos Welcome Live 2.0 - Live ISO Welcome Application\n"
"\n"
"Usage: soplos-welcome-live [OPTIONS]\n"
"\n"
"Options:\n"
"  -h, --help              Show this help message\n"
"  -v, --version           Show version information\n"
"  --lang=LANG             Set language (es, en, fr, de, pt, it, ro, ru)\n"
"  --theme=THEME           Set theme (base, light, dark)\n"
"  --chroot                Open chroot mode directly\n"
"  --debug                 Enable debug mode\n"
"\n"
"Examples:\n"
"  soplos-welcome-live                    # Start with auto-detected "
"settings\n"
"  soplos-welcome-live --lang=es          # Start in Spanish\n"
"  soplos-welcome-live --theme=dark       # Start with dark theme\n"
"  soplos-welcome-live --chroot           # Open chroot mode\n"
"\n"
"For more information, visit: https://soplos.org\n"
msgstr ""
"\n"
"Soplos Welcome Live 2.0 - Applicazione di Benvenuto ISO Live\n"
"\n"
"Uso: soplos-welcome-live [OPZIONI]\n"
"\n"
"Opzioni:\n"
"  -h, --help              Mostra questo messaggio di aiuto\n"
"  -v, --version           Mostra informazioni sulla versione\n"
"  --lang=LANG             Imposta lingua (es, en, fr, de, pt, it, ro, ru)\n"
"  --theme=TEMA            Imposta tema (base, light, dark)\n"
"  --chroot                Apri la modalità chroot direttamente\n"
"  --debug                 Abilita modalità debug\n"
"\n"
"Esempi:\n"
"  soplos-welcome-live                    # Avvia con impostazioni rilevate "
"automaticamente\n"
"  soplos-welcome-live --lang=es          # Avvia in spagnolo\n"
"  soplos-welcome-live --theme=dark       # Avvia con tema scuro\n"
"  soplos-welcome-live --chroot           # Apri modalità chroot\n"
"\n"
"Per ulteriori informazioni, visita: https://soplos.org\n"

