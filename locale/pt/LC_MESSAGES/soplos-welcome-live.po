#: core/application.py:310
msgid ""
"\n"
"Soplos Welcome Live 2.0 - Live ISO Welcome Application\n"
"\n"
"Usage: soplos-welcome-live [OPTIONS]\n"
"\n"
"Options:\n"
"  -h, --help              Show this help message\n"
"  -v, --version           Show version information\n"
"  --lang=LANG             Set language (es, en, fr, de, pt, it, ro, ru)\n"
"  --theme=THEME           Set theme (base, light, dark)\n"
"  --chroot                Open chroot mode directly\n"
"  --debug                 Enable debug mode\n"
"\n"
"Examples:\n"
"  soplos-welcome-live                    # Start with auto-detected "
"settings\n"
"  soplos-welcome-live --lang=es          # Start in Spanish\n"
"  soplos-welcome-live --theme=dark       # Start with dark theme\n"
"  soplos-welcome-live --chroot           # Open chroot mode\n"
"\n"
"For more information, visit: https://soplos.org\n"
msgstr ""
"\n"
"Soplos Welcome Live 2.0 - Aplicação de Boas-vindas ISO Live\n"
"\n"
"Uso: soplos-welcome-live [OPÇÕES]\n"
"\n"
"Opções:\n"
"  -h, --help              Mostrar esta mensagem de ajuda\n"
"  -v, --version           Mostrar informação da versão\n"
"  --lang=LANG             Definir idioma (es, en, fr, de, pt, it, ro, ru)\n"
"  --theme=TEMA            Definir tema (base, light, dark)\n"
"  --chroot                Abrir modo chroot diretamente\n"
"  --debug                 Ativar modo de depuração\n"
"\n"
"Exemplos:\n"
"  soplos-welcome-live                    # Iniciar com definições "
"detetadas\n"
"  soplos-welcome-live --lang=es          # Iniciar em espanhol\n"
"  soplos-welcome-live --theme=dark       # Iniciar com tema escuro\n"
"  soplos-welcome-live --chroot           # Abrir modo chroot\n"
"\n"
"Para mais informações, visite: https://soplos.org\n"

